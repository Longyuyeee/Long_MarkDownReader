{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Long编辑",
  "version": "0.4.7",
  "identifier": "com.longyuye.mdreader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Long编辑·md助手",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "wix": {
        "language": ["zh-CN"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
